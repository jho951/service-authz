AUTHZ_SERVICE_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-authz-service:latest
AUTHZ_SERVICE_HOST_BIND=127.0.0.1
AUTHZ_SERVICE_HOST_PORT=8084
SPRING_PROFILES_ACTIVE=prod
PERMISSION_INTERNAL_REQUEST_SECRET=local-authz-internal-secret
REDIS_HOST=central-redis
REDIS_PORT=6379
REDIS_TIMEOUT_MS=1000ms
PLATFORM_SECURITY_JWT_SECRET=change-this-to-a-long-random-value
AUTHZ_INTERNAL_JWT_SECRET=replace-with-authz-internal-jwt-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service
PLATFORM_SECURITY_IP_GUARD_ENABLED=true
PLATFORM_SECURITY_INTERNAL_ALLOW_CIDRS=127.0.0.1,::1
PLATFORM_SECURITY_RATE_LIMIT_ENABLED=true
SERVICE_SHARED_NETWORK=service-backbone-shared
