aws_region   = "ap-northeast-2"
project_name = "msa"
environment  = "prod"

service_name         = "authz-service"
service_runtime_name = "authz-service"
service_role         = "app-service"

create_vpc = false

existing_vpc_id             = "vpc-0123456789abcdef0"
existing_public_subnet_ids  = ["subnet-0publica123456789", "subnet-0publicc123456789"]
existing_private_subnet_ids = ["subnet-0appa1234567890", "subnet-0appc1234567890"]
existing_vpc_cidr           = "10.0.0.0/16"

alb_internal                         = true
alb_ingress_source_security_group_ids = ["sg-0gatewayecs12345678"]
private_dns_zone_id                  = "Z0123456789PRIVATE"
private_dns_name                     = "authz.internal.platform.local"

app_port      = 8084
desired_count = 2
task_cpu      = 512
task_memory   = 1024

health_check_path = "/health"

image_tag    = "latest"
enable_mysql = false

app_env = {
  REDIS_HOST       = "redis.internal.platform.local"
  REDIS_PORT       = "6379"
  REDIS_TIMEOUT_MS = "1000ms"
}

app_secret_env = {
  PERMISSION_INTERNAL_REQUEST_SECRET = "replace-with-shared-internal-secret"
}
